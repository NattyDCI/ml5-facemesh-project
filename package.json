{
  "name": "facemesh-app",
  "version": "1.0.0",
  "main": "main.js",
  
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron": "^41.0.3"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.miapp.facemesh",
    "productName": "FaceMeshApp",
    "files": ["**/*"],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}